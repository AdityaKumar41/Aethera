# Aethera API Environment Variables

# Database (Docker Compose)
DATABASE_URL="postgresql://aethera:aethera_dev_password@localhost:5432/aethera?schema=public"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# JWT (for API-to-API auth if needed)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Stellar Network
STELLAR_NETWORK="testnet"
ASSET_TOKEN_CONTRACT_ID=""
TREASURY_CONTRACT_ID=""
YIELD_DISTRIBUTOR_CONTRACT_ID=""
GOVERNANCE_CONTRACT_ID=""
ORACLE_CONTRACT_ID=""
USDC_CONTRACT_ID=""
GOVERNANCE_TOKEN_CONTRACT_ID=""
ADMIN_ADDRESS=""
DEPLOYER_SOURCE="deployer"
PLATFORM_FEE_BPS="1000"
MIN_PROPOSAL_TOKENS="100"
VOTING_PERIOD="86400"
EXECUTION_DELAY="172800"
QUORUM_PERCENTAGE="500"

# Relayer / Admin Keys (encrypted or secrets)
STAT_RELAYER_SECRET=""
ADMIN_RELAYER_SECRET_ENCRYPTED=""
STELLAR_SECRET_ENCRYPTION_KEY=""

# Wallet Encryption
WALLET_ENCRYPTION_SECRET="your-wallet-encryption-secret-change-in-production"

# Server
PORT=3001
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000"
