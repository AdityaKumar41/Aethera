# Aethera API Environment Variables

# Database (Docker Compose)
DATABASE_URL="postgresql://aethera:aethera_dev_password@localhost:5432/aethera?schema=public"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# JWT (for API-to-API auth if needed)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Stellar Network
STELLAR_NETWORK="testnet"

# Wallet Encryption
WALLET_ENCRYPTION_SECRET="your-wallet-encryption-secret-change-in-production"

# Server
PORT=3001
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:3000"
