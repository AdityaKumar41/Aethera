{
  "name": "@aethera/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Soroban smart contracts for Aethera platform",
  "scripts": {
    "build": "cargo build --target wasm32-unknown-unknown --release",
    "build:stellar": "stellar contract build",
    "test": "echo 'Skipping contract tests - run cargo test manually'",
    "test:cargo": "cargo test",
    "deploy:testnet": "stellar contract deploy --network testnet --source admin",
    "optimize": "stellar contract optimize --wasm target/wasm32-unknown-unknown/release/*.wasm"
  },
  "devDependencies": {
    "stellar-cli": "^1.0.3"
  }
}