generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  password               String?
  name                   String
  role                   UserRole     @default(UNSET)
  kycStatus              KYCStatus    @default(PENDING)
  kycSubmittedAt         DateTime?
  kycVerifiedAt          DateTime?
  kycDocuments           Json?
  stellarPubKey          String?      @unique
  stellarSecretEncrypted String?
  phone                  String?
  company                String?
  address                String?
  country                String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  investments            Investment[]
  projects               Project[]
  yieldClaims            YieldClaim[]
  tokenSales             TokenTransfer[]  @relation("TokenSales")
  tokenPurchases         TokenTransfer[]  @relation("TokenPurchases")

  @@index([role])
  @@index([kycStatus])
}

model Project {
  id                        String              @id @default(cuid())
  installerId               String
  name                      String
  description               String
  location                  String
  country                   String
  capacity                  Float
  panelType                 String?
  inverterType              String?
  estimatedAnnualProduction Float?
  expectedYield             Float
  fundingTarget             Decimal             @db.Decimal(18, 2)
  fundingRaised             Decimal             @default(0) @db.Decimal(18, 2)
  pricePerToken             Decimal             @db.Decimal(18, 6)
  tokenSymbol               String?             @unique
  tokenContractId           String?             @unique
  totalTokens               Int?
  tokensRemaining           Int?
  startDate                 DateTime?
  estimatedCompletionDate   DateTime?
  actualCompletionDate      DateTime?
  status                    ProjectStatus       @default(DRAFT)
  approvedAt                DateTime?
  approvedBy                String?
  rejectionReason           String?
  documents                 Json?
  images                    Json?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  totalEnergyProduced       Decimal?            @db.Decimal(18, 4)
  currentYieldRate          Float?
  lastProductionUpdate      DateTime?
  carbonCredits             Decimal?            @db.Decimal(18, 4)
  fundingModel              FundingModel        @default(FULL_UPFRONT)
  totalEscrowedAmount       Decimal             @default(0) @db.Decimal(18, 2)
  totalReleasedAmount       Decimal             @default(0) @db.Decimal(18, 2)
  milestones                ProjectMilestone[]
  investments               Investment[]
  productionData            ProductionData[]
  installer                 User                @relation(fields: [installerId], references: [id])
  tokenTransfers            TokenTransfer[]
  yieldDistributions        YieldDistribution[]
  iotDevices                IoTDevice[]

  @@index([installerId])
  @@index([status])
  @@index([tokenSymbol])
}

model OracleProvider {
  id                  String           @id @default(cuid())
  name                String
  description         String?
  apiKeyHash          String           @unique
  publicKey           String           @unique
  status              OracleStatus     @default(PENDING)
  approvedAt          DateTime?
  approvedBy          String?
  trustScore          Int              @default(50)
  totalSubmissions    Int              @default(0)
  disputedSubmissions Int              @default(0)
  rateLimit           Int              @default(100)
  lastSubmissionAt    DateTime?
  contactEmail        String?
  webhookUrl          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  disputes            OracleDispute[]
  productionData      ProductionData[]

  @@index([status])
  @@index([trustScore])
}

model ProductionData {
  id               String          @id @default(cuid())
  projectId        String
  energyProduced   Decimal         @db.Decimal(18, 4)
  recordedAt       DateTime
  source           String
  verifiedBy       String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  disputeId        String?
  disputed         Boolean         @default(false)
  oracleProviderId String?
  periodEnd        DateTime?
  periodStart      DateTime?
  signature        String?
  signatureValid   Boolean?
  signedPayload    String?
  carbonCredits    Decimal?        @db.Decimal(18, 4)
  onChainCommitAt  DateTime?
  onChainCommitTx  String?         @unique
  iotDeviceId      String?
  iotDevice        IoTDevice?      @relation(fields: [iotDeviceId], references: [id])
  oracleProvider   OracleProvider? @relation(fields: [oracleProviderId], references: [id])
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([recordedAt])
  @@index([oracleProviderId])
  @@index([iotDeviceId])
  @@index([disputed])
}

model OracleDispute {
  id               String         @id @default(cuid())
  productionDataId String
  oracleProviderId String
  filedBy          String
  reason           String
  evidence         Json?
  status           DisputeStatus  @default(OPEN)
  resolvedBy       String?
  resolution       String?
  resolvedAt       DateTime?
  trustScoreChange Int?
  dataInvalidated  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  oracleProvider   OracleProvider @relation(fields: [oracleProviderId], references: [id])

  @@index([oracleProviderId])
  @@index([status])
}

model Investment {
  id              String             @id @default(cuid())
  investorId      String
  projectId       String
  amount          Decimal            @db.Decimal(18, 2)
  tokenAmount     Int
  pricePerToken   Decimal            @db.Decimal(18, 6)
  status          InvestmentStatus   @default(PENDING)
  txHash          String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  mintConfirmedAt DateTime?
  mintStatus      TransactionStatus?
  mintTxHash      String?
  txConfirmedAt   DateTime?
  txError         String?
  txLedger        Int?
  txRetryCount    Int                @default(0)
  txSubmittedAt   DateTime?
  investor        User               @relation(fields: [investorId], references: [id])
  project         Project            @relation(fields: [projectId], references: [id])

  @@index([investorId])
  @@index([projectId])
  @@index([status])
  @@index([txHash])
}

model YieldDistribution {
  id            String       @id @default(cuid())
  projectId     String
  period        DateTime
  totalRevenue  Decimal      @db.Decimal(18, 2)
  platformFee   Decimal      @db.Decimal(18, 2)
  totalYield    Decimal      @db.Decimal(18, 2)
  yieldPerToken Decimal      @db.Decimal(18, 10)
  distributed   Boolean      @default(false)
  distributedAt DateTime?
  txHash        String?
  onChainDistributionId BigInt?
  metadata      Json?
  createdAt     DateTime     @default(now())
  claims        YieldClaim[]
  project       Project      @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([period])
}

model YieldClaim {
  id             String            @id @default(cuid())
  distributionId String
  investorId     String
  tokenAmount    Int
  amount         Decimal           @db.Decimal(18, 2)
  claimed        Boolean           @default(false)
  claimedAt      DateTime?
  txHash         String?
  createdAt      DateTime          @default(now())
  distribution   YieldDistribution @relation(fields: [distributionId], references: [id])
  investor       User              @relation(fields: [investorId], references: [id])

  @@unique([distributionId, investorId])
  @@index([investorId])
}

model TransactionLog {
  id            String   @id @default(cuid())
  type          String
  userId        String?
  projectId     String?
  amount        Decimal? @db.Decimal(18, 2)
  txHash        String   @unique
  status        String
  sourceAccount String?
  destAccount   String?
  metadata      Json?
  error         String?
  createdAt     DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([projectId])
}

model TokenTransfer {
  id              String           @id @default(cuid())
  projectId       String
  fromUserId      String
  toUserId        String
  tokenAmount     Int
  pricePerToken   Decimal          @db.Decimal(18, 6)
  totalPrice      Decimal          @db.Decimal(18, 2)
  status          TransferStatus   @default(PENDING)
  txHash          String?          @unique
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  project         Project          @relation(fields: [projectId], references: [id])
  seller          User             @relation("TokenSales", fields: [fromUserId], references: [id])
  buyer           User             @relation("TokenPurchases", fields: [toUserId], references: [id])

  @@index([projectId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
}

model SystemSettings {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  INVESTOR
  INSTALLER
  ADMIN
  UNSET
}

enum KYCStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  FUNDING
  FUNDED
  ACTIVE_PENDING_DATA
  ACTIVE
  COMPLETED
}

enum InvestmentStatus {
  PENDING
  CONFIRMED
  FAILED
  PENDING_ONCHAIN
}

enum TransactionStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
  EXPIRED
}

enum OracleStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_VALID
  RESOLVED_INVALID
  ESCALATED
}

model IoTDevice {
  id             String           @id @default(cuid())
  projectId      String
  publicKey      String           @unique
  status         DeviceStatus     @default(ACTIVE)
  lastSeenAt     DateTime?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  project        Project          @relation(fields: [projectId], references: [id])
  productionData ProductionData[]

  @@index([projectId])
  @@index([publicKey])
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  COMPLETED
  REJECTED
  EXPIRED
}

model ProjectMilestone {
  id                String             @id @default(cuid())
  projectId         String
  name              String
  description       String
  order             Int
  releasePercentage Float              // Percentage of total funds to release
  releaseAmount     Decimal            @db.Decimal(18, 2)
  status            MilestoneStatus    @default(PENDING)
  verificationMethod VerificationMethod
  proofDocuments    Json?              // Array of URLs
  submittedAt       DateTime?
  verifiedAt        DateTime?
  releasedAt        DateTime?
  verificationTxHash String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
  RELEASED
}

enum VerificationMethod {
  DOCUMENT
  PHOTO
  IOT
  ORACLE
}

enum FundingModel {
  FULL_UPFRONT
  MILESTONE_BASED
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  userId        String?
  previousState String?
  newState      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
